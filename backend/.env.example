KNOWLEDGE_OS_DATABASE_URL=postgresql+asyncpg://knowledge_os:knowledge_os@localhost:5432/knowledge_os
KNOWLEDGE_OS_JWT_SECRET=replace-with-at-least-32-random-characters
KNOWLEDGE_OS_ACCESS_TOKEN_TTL_MINUTES=15
KNOWLEDGE_OS_REFRESH_TOKEN_TTL_DAYS=30
KNOWLEDGE_OS_SECURE_COOKIES=false
KNOWLEDGE_OS_CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173", "http://127.0.0.1:3000", "http://127.0.0.1:5173"]

# Provider Selection (azure_blob, google_gcs, local)
KNOWLEDGE_OS_STORAGE_PROVIDER=azure_blob
# Google Cloud Service Account Path & GCS Bucket name
KNOWLEDGE_OS_GOOGLE_APPLICATION_CREDENTIALS=/Users/nahyanm/Documents/AutonomizeAI/ai-studio/ai-studio-v2/service-acc.json
KNOWLEDGE_OS_GCS_BUCKET_NAME=documents

# Embedding Provider Selection (openai, gemini)
KNOWLEDGE_OS_EMBEDDING_PROVIDER=openai
# Gemini API Key
KNOWLEDGE_OS_GEMINI_API_KEY=your_gemini_api_key_here


